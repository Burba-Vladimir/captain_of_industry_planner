# Auto-detect text files and normalize line endings to LF in repo
* text=auto eol=lf

# Explicitly text files
*.py    text eol=lf
*.html  text eol=lf
*.json  text eol=lf
*.sql   text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.css   text eol=lf
*.js    text eol=lf

# Binary files — no line-ending conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
