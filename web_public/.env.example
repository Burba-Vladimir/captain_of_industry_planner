# Скопируй в .env и заполни реальными значениями
# НЕ коммитить .env в git!

# ── База данных ───────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/coi_public

# ── Flask ─────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret-string
FLASK_ENV=development

# ── Google OAuth ──────────────────────────────────────────────────
# Получить на: console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Steam OpenID ──────────────────────────────────────────────────
# Получить на: steamcommunity.com/dev/apikey
STEAM_API_KEY=your-steam-api-key

# ── Email (SMTP) для авторизации ─────────────────────────────────
# Если не задано — код выводится в консоль (dev-режим)
# Пример для Gmail: smtp.gmail.com, порт 587, App Password
# Пример для Mailgun: smtp.mailgun.org, порт 587
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=CoI Planner <your@gmail.com>

# ── Лимиты для free-tier пользователей ───────────────────────────
FREE_MAX_PRIVATE_COMPLEXES=10
FREE_MAX_PUBLIC_COMPLEXES=3
