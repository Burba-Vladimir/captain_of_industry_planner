# Скопируй в .env и заполни реальными значениями
# НЕ коммитить .env в git!

# ── База данных ───────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/coi_public

# ── Flask ─────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-secret-string
FLASK_ENV=development

# ── Google OAuth ──────────────────────────────────────────────────
# Получить на: console.cloud.google.com → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Steam OpenID ──────────────────────────────────────────────────
# Получить на: steamcommunity.com/dev/apikey
STEAM_API_KEY=your-steam-api-key

# ── Email (SMTP) для авторизации ─────────────────────────────────
# Если SMTP_HOST не задан — код выводится в консоль (только dev-режим!)
#
# Gmail App Password (бесплатно, 500 писем/день):
#   1. Включить 2FA: myaccount.google.com → Безопасность → Двухэтапная аутентификация
#   2. Создать пароль: myaccount.google.com → Безопасность → Пароли приложений
#      → Название: "CoI Planner" → Создать
#   3. Скопировать 16 символов (без пробелов) в SMTP_PASS
#   Проверить: flask send-test-email your@email.com
#
# SMTP_FROM до покупки домена: оставить пустым (подставится SMTP_USER автоматически)
# SMTP_FROM после покупки домена: noreply@yourdomain.com (добавить SPF в DNS)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=abcdefghijklmnop
SMTP_FROM=

# ── Лимиты ───────────────────────────────────────────────────────
MAX_COMPLEXES_PER_USER=30          # максимум комплексов на аккаунт (premium — без ограничений)
# RATELIMIT_STORAGE_URI=redis://localhost:6379/0  # для продакшена; по умолчанию in-memory

# ── URL сайта (для OG-тегов и OAuth redirect) ────────────────────
# До покупки домена: оставить пустым (берётся из request.host_url автоматически)
# После покупки домена раскомментировать:
# SITE_URL=https://yourdomain.com

# ── Продакшн SECRET_KEY ───────────────────────────────────────────
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
